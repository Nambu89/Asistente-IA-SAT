PYTHONPATH=.

# Azure OpenAI / Azure AI Foundry
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_MAX_TOKENS=1000
AZURE_OPENAI_TEMPERATURE=0.3

# Optional vector / index metadata
AZURE_AI_FOUNDRY_VECTOR_INDEX=replace-me
AZURE_AI_FOUNDRY_GENERIC_INDEX=replace-me
AZURE_AI_FOUNDRY_SUBSCRIPTION_ID=replace-me
AZURE_AI_FOUNDRY_STORAGE_URI=https://yourstorage.blob.core.windows.net/

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=replace-me
AZURE_SEARCH_INDEX_NAME=technical-manuals-index

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=replace-me
REDIS_PORT=6379
REDIS_SSL=false
REDIS_TTL=3600

# Runtime tuning
MEMORY_CACHE_SIZE=500
MAX_CONTEXT_LENGTH=12000
REQUEST_TIMEOUT=60
WEB_CONCURRENCY=2
WORKER_MAX_REQUESTS=1000
WORKER_TIMEOUT=120

# Web security / browser access
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
